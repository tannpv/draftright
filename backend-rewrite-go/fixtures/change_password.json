{
  "name": "change-password",
  "method": "POST",
  "path": "/auth/change-password",
  "headers": {
    "Content-Type": "application/json",
    "Authorization": "Bearer REPLACE_WITH_DEV_NODE_TOKEN"
  },
  "body": {
    "current_password": "REPLACE_WITH_DEV_SEED_PASSWORD",
    "new_password": "REPLACE_WITH_NEW_PASSWORD"
  },
  "ignore_value_of": ["request_id"]
}
