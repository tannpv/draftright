---
import BaseLayout from '../layouts/BaseLayout.astro';
import ForgotPasswordForm from '../components/ForgotPasswordForm.tsx';
---
<BaseLayout title="Forgot password — DraftRight" description="Reset your DraftRight password. We'll email you a 6-digit code.">
  <section class="py-20 px-6">
    <div class="max-w-2xl mx-auto text-center mb-10">
      <h1 class="text-4xl font-bold text-white mb-4">Forgot your password?</h1>
      <p class="text-gray-400">Enter your email and we'll send a 6-digit reset code.</p>
    </div>
    <ForgotPasswordForm client:load />
  </section>
</BaseLayout>
