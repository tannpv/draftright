---
import BaseLayout from '../layouts/BaseLayout.astro';
import AccountPage from '../components/AccountPage.tsx';
---
<BaseLayout title="My account — DraftRight" description="Manage your DraftRight subscription, plan, and billing.">
  <section class="py-20 px-6">
    <div class="max-w-2xl mx-auto text-center mb-10">
      <h1 class="text-3xl font-bold text-white mb-2">My account</h1>
      <p class="text-gray-400">Manage your subscription and plan.</p>
    </div>
    <AccountPage client:load />
  </section>
</BaseLayout>
