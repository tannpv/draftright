---
import BaseLayout from '../layouts/BaseLayout.astro';
import VerifyEmailForm from '../components/VerifyEmailForm.tsx';
---
<BaseLayout title="Verify your email — DraftRight" description="Enter the 6-digit code we sent to your inbox to activate your DraftRight account.">
  <section class="py-20 px-6">
    <div class="max-w-2xl mx-auto text-center mb-10">
      <h1 class="text-4xl font-bold text-white mb-4">Check your email</h1>
      <p class="text-gray-400">We sent a 6-digit verification code. Enter it below.</p>
    </div>
    <VerifyEmailForm client:load />
  </section>
</BaseLayout>
