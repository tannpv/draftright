---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResetPasswordForm from '../components/ResetPasswordForm.tsx';
---
<BaseLayout title="Reset password — DraftRight" description="Enter the 6-digit code we emailed you and choose a new password.">
  <section class="py-20 px-6">
    <div class="max-w-2xl mx-auto text-center mb-10">
      <h1 class="text-4xl font-bold text-white mb-4">Reset your password</h1>
      <p class="text-gray-400">Enter the code from your email and choose a new password.</p>
    </div>
    <ResetPasswordForm client:load />
  </section>
</BaseLayout>
