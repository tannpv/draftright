---
import BaseLayout from '../../layouts/BaseLayout.astro';
// Server-render the static success page.  Lemon Squeezy's checkout
// redirects here with `?ref=PAY-XXX` after a successful payment;
// iOS Universal Link / Android App Link grab the same URL and pop
// the app back to the Subscription screen.  Web visitors and desktops
// see this page as the canonical confirmation.
---
<BaseLayout
  title="Payment confirmed — DraftRight"
  description="Your DraftRight Pro subscription is active.">
  <section class="py-20 px-6">
    <div class="max-w-xl mx-auto text-center">
      <div class="text-7xl mb-6" aria-hidden="true">✅</div>
      <h1 class="text-3xl font-bold text-white mb-3">Payment confirmed</h1>
      <p class="text-gray-300 mb-8">
        Your DraftRight Pro subscription is now active.
        We just sent a receipt to the email you used at checkout.
      </p>

      <!--
        Mobile fallback CTA — on iOS / Android with App Link verified
        this entire page is bypassed by the OS, but if the user
        opened the link in a desktop browser or before App Link
        verification finished, this button gives them a one-tap
        way back into the app.
      -->
      <a
        href="https://draftright.info/payment/success"
        class="inline-block px-6 py-3 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-semibold"
      >
        Return to the app
      </a>

      <p class="text-gray-500 mt-8 text-sm">
        Already in the app?  Pull down on the Subscription screen to refresh.
      </p>
    </div>
  </section>
</BaseLayout>
