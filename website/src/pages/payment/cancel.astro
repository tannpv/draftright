---
import BaseLayout from '../../layouts/BaseLayout.astro';
// Lemon Squeezy redirects here when the user backs out of the
// hosted-checkout page (today the LS strategy defaults to a single
// redirect_url, so this is reached when the user manually clicks
// "Cancel" inside checkout).  The mobile app catches the same URL
// via App Link and shows a "Checkout cancelled" toast.
---
<BaseLayout
  title="Checkout cancelled — DraftRight"
  description="No charge was made.  You can pick a different payment method any time.">
  <section class="py-20 px-6">
    <div class="max-w-xl mx-auto text-center">
      <div class="text-7xl mb-6" aria-hidden="true">↩️</div>
      <h1 class="text-3xl font-bold text-white mb-3">Checkout cancelled</h1>
      <p class="text-gray-300 mb-8">
        No charge was made.  You can pick a different payment method
        any time from the app's Subscription screen.
      </p>
      <a
        href="https://draftright.info/pricing"
        class="inline-block px-6 py-3 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-semibold"
      >
        See plans again
      </a>
    </div>
  </section>
</BaseLayout>
