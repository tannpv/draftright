---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignupForm from '../components/SignupForm.tsx';
---
<BaseLayout title="Sign up — DraftRight" description="Create your DraftRight account in seconds. Free forever, no credit card required.">
  <section class="py-20 px-6">
    <div class="max-w-2xl mx-auto text-center mb-10">
      <h1 class="text-4xl font-bold text-white mb-4">Create your account</h1>
      <p class="text-gray-400">Free forever. 20 rewrites per day, no credit card.</p>
    </div>
    <SignupForm client:load />
  </section>
</BaseLayout>
