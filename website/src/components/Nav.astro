---
---
<nav class="fixed top-0 inset-x-0 z-50 border-b border-dark-border bg-dark-bg/80 backdrop-blur-lg">
  <div class="mx-auto max-w-7xl flex items-center justify-between px-6 py-3">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-white font-bold text-xl">
      <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-brand-400 text-white text-lg leading-none">&#9998;</span>
      <span>DraftRight</span>
    </a>

    <!-- Links -->
    <div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-300">
      <a href="/#features" class="hover:text-white transition-colors">Features</a>
      <a href="/pricing" class="hover:text-white transition-colors">Pricing</a>
      <a href="/feedback" class="hover:text-white transition-colors">Feedback</a>
      <a href="/download" class="hover:text-white transition-colors">Download</a>
    </div>

    <!-- CTAs — guest links hidden until JS confirms logged-out (avoids flash) -->
    <div class="flex items-center gap-4">
      <!-- Guest (logged out) -->
      <a data-auth="guest" href="/login" style="display:none"
        class="hidden sm:inline-block text-sm font-medium text-gray-300 hover:text-white transition-colors">
        Log in
      </a>
      <a data-auth="guest" href="/signup" style="display:none"
        class="hidden sm:inline-block text-sm font-medium text-gray-300 hover:text-white transition-colors">
        Sign up
      </a>
      <!-- Authenticated -->
      <a data-auth="user" href="/account" style="display:none"
        class="hidden sm:inline-block text-sm font-medium text-gray-300 hover:text-white transition-colors">
        Account
      </a>
      <button data-auth="user" id="nav-logout" type="button" style="display:none"
        class="hidden sm:inline-block text-sm font-medium text-gray-300 hover:text-white transition-colors">
        Log out
      </button>
      <a
        href="/#playground"
        class="rounded-full bg-brand-400 px-5 py-2 text-sm font-semibold text-white hover:bg-brand-500 transition-colors"
      >
        Try It Free
      </a>
    </div>
  </div>
</nav>

<script is:inline>
  // Toggle nav auth links based on the stored session token. Both sets start
  // hidden (inline style) to avoid a flash of the wrong state; clearing the
  // inline style lets the responsive Tailwind classes take over.
  (function () {
    var loggedIn = !!localStorage.getItem('dr_access_token');
    document.querySelectorAll('[data-auth="guest"]').forEach(function (el) {
      el.style.display = loggedIn ? 'none' : '';
    });
    document.querySelectorAll('[data-auth="user"]').forEach(function (el) {
      el.style.display = loggedIn ? '' : 'none';
    });
    var logout = document.getElementById('nav-logout');
    if (logout) {
      logout.addEventListener('click', function () {
        localStorage.removeItem('dr_access_token');
        localStorage.removeItem('dr_refresh_token');
        window.location.href = '/';
      });
    }
  })();
</script>
