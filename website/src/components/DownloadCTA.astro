---
// Current published versions (mirror /updates/latest).
const MACOS_VERSION = '2.3.30';
const WINDOWS_VERSION = '2.3.31';
const BASE = '/downloads';

// Microsoft Store listing for the Windows app.
const MS_STORE_URL = 'https://apps.microsoft.com/detail/9p5wwdggvcs3';
---
<section class="py-24">
  <div class="mx-auto max-w-5xl px-6">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">Download DraftRight</h2>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto">
        Available now on macOS and Windows — or try it instantly in your browser, no install required.
      </p>
    </div>

    <!-- Available now -->
    <h3 class="text-2xl font-semibold mb-6 text-center">Available now</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      <!-- macOS -->
      <a href={`${BASE}/DraftRight-macOS-${MACOS_VERSION}.dmg`}
         class="group rounded-2xl border border-dark-border bg-dark-card p-6 hover:border-brand-400 transition-all">
        <div class="text-center">
          <div class="text-4xl mb-3">&#127815;</div>
          <h4 class="text-lg font-semibold text-white">macOS <span class="text-xs text-gray-500">v{MACOS_VERSION}</span></h4>
          <p class="text-sm text-gray-400 mt-1">Universal · Signed &amp; notarized · macOS 13+</p>
          <div class="mt-4 inline-flex items-center gap-2 text-brand-400 font-medium text-sm group-hover:translate-x-1 transition-transform">
            Download .dmg <span>&rarr;</span>
          </div>
        </div>
      </a>

      <!-- Windows -->
      <div class="rounded-2xl border border-dark-border bg-dark-card p-6 hover:border-brand-400 transition-all">
        <div class="text-center">
          <div class="text-4xl mb-3">&#128421;&#65039;</div>
          <h4 class="text-lg font-semibold text-white">Windows <span class="text-xs text-gray-500">v{WINDOWS_VERSION}</span></h4>
          <p class="text-sm text-gray-400 mt-1">Microsoft Store · Win 10/11</p>
          {MS_STORE_URL && (
            <a href={MS_STORE_URL}
               class="mt-4 block text-brand-400 font-medium text-sm hover:underline">
              Get it from Microsoft Store &rarr;
            </a>
          )}
          <a href={`${BASE}/DraftRight-Setup-Windows-${WINDOWS_VERSION}-x64.exe`}
             class={`block text-gray-400 text-xs hover:text-brand-400 hover:underline ${MS_STORE_URL ? 'mt-2' : 'mt-4'}`}>
            Or direct installer (x64) &rarr;
          </a>
        </div>
      </div>

      <!-- Web -->
      <a href="/#playground"
         class="group rounded-2xl border border-dark-border bg-dark-card p-6 hover:border-brand-400 transition-all">
        <div class="text-center">
          <div class="text-4xl mb-3">&#127760;</div>
          <h4 class="text-lg font-semibold text-white">Web</h4>
          <p class="text-sm text-gray-400 mt-1">No install · Runs in your browser</p>
          <div class="mt-4 inline-flex items-center gap-2 text-brand-400 font-medium text-sm group-hover:translate-x-1 transition-transform">
            Open Web Playground <span>&rarr;</span>
          </div>
        </div>
      </a>
    </div>

    <!-- Coming soon -->
    <h3 class="text-2xl font-semibold mb-2 text-center">Coming soon</h3>
    <p class="text-center text-sm text-gray-500 mb-6">iOS, Android, and Linux are in active development.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      <!-- iOS -->
      <div class="rounded-2xl border border-dark-border bg-dark-card/50 p-6 text-center opacity-80">
        <div class="text-4xl mb-3">&#128241;</div>
        <h4 class="text-lg font-semibold text-white">iOS</h4>
        <p class="text-sm text-gray-400 mt-1">iPhone &amp; iPad · App + keyboard</p>
        <span class="mt-4 inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-amber-500/15 text-amber-300">Coming soon</span>
      </div>
      <!-- Android -->
      <div class="rounded-2xl border border-dark-border bg-dark-card/50 p-6 text-center opacity-80">
        <div class="text-4xl mb-3">&#129302;</div>
        <h4 class="text-lg font-semibold text-white">Android</h4>
        <p class="text-sm text-gray-400 mt-1">App + AI keyboard</p>
        <span class="mt-4 inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-amber-500/15 text-amber-300">Coming soon</span>
      </div>
      <!-- Linux -->
      <div class="rounded-2xl border border-dark-border bg-dark-card/50 p-6 text-center opacity-80">
        <div class="text-4xl mb-3">&#128039;</div>
        <h4 class="text-lg font-semibold text-white">Linux</h4>
        <p class="text-sm text-gray-400 mt-1">GTK 4 native app</p>
        <span class="mt-4 inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-amber-500/15 text-amber-300">Coming soon</span>
      </div>
    </div>

    <!-- Install instructions -->
    <details class="mb-8 rounded-2xl border border-dark-border bg-dark-card p-6">
      <summary class="cursor-pointer text-lg font-semibold text-white hover:text-brand-400">
        Install instructions
      </summary>
      <div class="mt-4 space-y-4 text-sm text-gray-300">
        <div>
          <h5 class="font-semibold text-white mb-1">macOS</h5>
          <p>Open the downloaded <code>DraftRight-macOS-{MACOS_VERSION}.dmg</code> and drag <strong>DraftRight</strong> to your Applications folder. The app is signed &amp; notarized by Apple, so it opens with a normal double-click. On first launch, grant Accessibility access in <strong>System Settings &rarr; Privacy &amp; Security &rarr; Accessibility</strong> so DraftRight can rewrite text in other apps. Press your hotkey on selected text to rewrite.</p>
        </div>
        <div>
          <h5 class="font-semibold text-white mb-1">Windows</h5>
          <p>Install from the Microsoft Store for automatic updates, or run the direct installer. The app lives in the system tray; press <strong>Ctrl+Shift+R</strong> on selected text to rewrite.</p>
        </div>
        <div>
          <h5 class="font-semibold text-white mb-1">Web</h5>
          <p>No install needed — open the <a href="/#playground" class="text-brand-400 hover:underline">Web Playground</a>, paste your text, pick a tone, and rewrite.</p>
        </div>
      </div>
    </details>

    <!-- Footer note -->
    <p class="text-center text-sm text-gray-500 mt-8">
      All apps connect to <code class="text-brand-400">api.draftright.info</code>. Sign in with any account or create a new one — all features included.
    </p>
  </div>
</section>
