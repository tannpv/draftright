<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.draftright.v2</string>
	</array>
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.draftright.v2.shared</string>
	</array>
	<!-- iOS Universal Links.  Each domain needs its own entry; iOS
	     does NOT inherit between subdomains.  Both prod + dev
	     declared so the same IPA serves either backend (user can
	     swap Settings → Server → Backend URL between them without
	     a rebuild). -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:draftright.info</string>
		<string>applinks:dev.draftright.info</string>
	</array>
	<!-- Sign in with Apple capability.  Backed by the same Apple
	     Developer-portal entitlement that App Store Connect generates
	     when the App ID has "Sign In with Apple" enabled.  Required
	     by App Store Guideline 4.8: any third-party login (Google,
	     Facebook, …) must be paired with this. -->
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
</dict>
</plist>
